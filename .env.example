# ─────────────────────────────────────────────────────────────────────────────
# SSOLAP 환경변수 템플릿
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── 공통 ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL (프로덕션 docker-compose.yml) ───────────────────────────────────
POSTGRES_DB=ssolap
POSTGRES_USER=ssolap
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── 웹 (Next.js) ──────────────────────────────────────────────────────────────
# nginx 를 통해 /api/* 로 접근하므로 도메인 없이 사용 시 아래 값 그대로 사용 가능
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_WS_URL=ws://localhost
NEXT_PUBLIC_APP_NAME=SSOLAP
NEXT_PUBLIC_APP_VERSION=0.1.0

# 도메인이 있는 경우:
# NEXT_PUBLIC_API_URL=https://your-domain.com
# NEXT_PUBLIC_WS_URL=wss://your-domain.com

# ── API (FastAPI) ──────────────────────────────────────────────────────────────
# 개발: SQLite (Docker 없어도 바로 실행)
# DATABASE_URL=sqlite+aiosqlite:///./ssolap_dev.db

# 프로덕션: PostgreSQL (docker-compose.yml 에서 자동 조합)
# DATABASE_URL=postgresql+asyncpg://ssolap:CHANGE_ME@postgres:5432/ssolap

# ── JWT 인증 ───────────────────────────────────────────────────────────────────
# 32자 이상 랜덤 문자열로 반드시 변경하세요!
# 생성 예시: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis (선택 — 없으면 메모리 캐시 사용) ────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── 파일 업로드 ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=200

# ── CORS ──────────────────────────────────────────────────────────────────────
# capacitor://localhost — Android/iOS Capacitor 앱 오리진 (모바일 APK)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,capacitor://localhost,https://localhost

# ── S포인트 설정 ──────────────────────────────────────────────────────────────
DAILY_POINT_CAP=500
POINT_CHECKIN_REWARD=10
POINT_POST_REWARD=20
POINT_COMMENT_REWARD=5

# ── Capacitor / 모바일 앱 ─────────────────────────────────────────────────────
# APK 빌드 시 Capacitor가 로드할 서버 URL (프로덕션 배포 주소)
# CAPACITOR_SERVER_URL=https://your-domain.com

# ── 디버그 모드 (프로덕션: false) ─────────────────────────────────────────────
DEBUG=false
