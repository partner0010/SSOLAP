# ─────────────────────────────────────────────────────────────────────────────
# SSOLAP 환경변수 템플릿
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── 공통 ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── 웹 (Next.js) ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=SSOLAP
NEXT_PUBLIC_APP_VERSION=0.1.0

# ── API (FastAPI) ──────────────────────────────────────────────────────────────
# 개발: SQLite (Docker 없어도 바로 실행)
DATABASE_URL=sqlite+aiosqlite:///./ssolap_dev.db

# 프로덕션 (나중에): PostgreSQL
# DATABASE_URL=postgresql+asyncpg://ssolap:password@localhost:5432/ssolap

# ── JWT 인증 ───────────────────────────────────────────────────────────────────
# 32자 이상 랜덤 문자열로 반드시 변경하세요!
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis (선택 — 없으면 메모리 캐시 사용) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── 파일 업로드 ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── S포인트 설정 ──────────────────────────────────────────────────────────────
DAILY_POINT_CAP=500
POINT_CHECKIN_REWARD=10
POINT_POST_REWARD=20
